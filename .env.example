# ── Gateway ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT (compartido: gateway lo verifica, auth-service lo firma) ──
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# ── Base de datos (compartida por todos los servicios) ────────
# Docker Compose local:  DB_HOST=mysql
# Externo:               DB_HOST=<host o IP>
DB_HOST=mysql
DB_PORT=3306
DB_NAME=frontefolio
DB_USER=root
DB_PASSWORD=yourpassword

# ── Pago simulado ─────────────────────────────────────────────
# Números de tarjeta que el simulador acepta como válidos
VALID_CARDS=4111111111111111,5500005555555554,4000000000000002

# ── Frontend URLs (CORS — solo en el gateway) ─────────────────
FRONTEND_CUSTOMER_URL=http://localhost:5173
FRONTEND_ADMIN_URL=http://localhost:5174

# ── URLs de servicios (desarrollo local sin Docker) ───────────
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
CATALOG_SERVICE_URL=http://localhost:3003
ORDER_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005
LOGISTICS_SERVICE_URL=http://localhost:3006
CHAT_SERVICE_URL=http://localhost:3007
